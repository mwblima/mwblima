---
import { siteConfig } from "../config";
const hasArticles = siteConfig.articles && siteConfig.articles.length > 0;
const base = import.meta.env.BASE_URL;
---

{
  hasArticles && (
    <section id="articles" class="py-24 sm:py-32 bg-[var(--color-bg-base)] border-b border-gray-200">
      <div class="max-w-[1400px] mx-auto px-8 w-full flex flex-col lg:flex-row">
        
        <!-- Left Static Column -->
        <div class="w-full lg:w-[30%] xl:w-[25%] shrink-0 flex flex-col pr-8 lg:pr-12 xl:pr-16 mb-12 lg:mb-0">
          <div class="sticky top-32">
            <span class="text-xs font-mono font-bold tracking-[0.2em] uppercase text-[var(--color-accent-primary)] mb-6 block">Latest Articles</span>
            <h2 class="text-4xl lg:text-5xl font-display text-gray-900 mb-6 font-medium tracking-tight leading-tight">
              Ideas, insights<br/>and research
            </h2>
            <p class="text-gray-600 font-sans mb-8 leading-relaxed text-sm md:text-base max-w-sm">
              I share knowledge about data engineering, AI, architecture and systems thinking.
            </p>
            <a href={`${base}/articles`} class="text-sm font-semibold text-[var(--color-accent-primary)] hover:opacity-80 transition-all flex items-center gap-2 group">
              View all articles 
              <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <!-- Right Scrolling Column -->
        <div class="w-full lg:w-[70%] xl:w-[75%] relative min-w-0">
          <div class="hidden lg:flex justify-end gap-3 mb-6 absolute -top-20 right-0">
             <button id="articles-prev" class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:border-gray-900 transition-colors cursor-pointer" aria-label="Previous">
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
             </button>
             <button id="articles-next" class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center text-gray-900 border-gray-900 hover:bg-gray-50 transition-colors cursor-pointer" aria-label="Next">
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
             </button>
          </div>

          <div id="articles-scroll" class="flex overflow-x-auto gap-6 snap-x snap-mandatory hide-scrollbar pb-8 -mx-8 px-8 lg:mx-0 lg:px-0">
            {siteConfig.articles.map((article) => {
              const Component = article.link ? "a" : "div";
              const linkProps = article.link ? { href: article.link, target: "_blank", rel: "noopener noreferrer" } : {};

              return (
                <Component
                  {...linkProps}
                  class="w-[85vw] sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] shrink-0 snap-center sm:snap-start group flex flex-col bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-xl hover:border-gray-300 transition-all duration-300"
                >
                  <!-- Header Image Placeholder -->
                  <div class="w-full h-[180px] bg-[#111318] relative overflow-hidden flex items-center justify-center">
                    {article.image ? (
                      <img src={`${base}${article.image}`} alt={article.title} class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-500 group-hover:scale-105" />
                    ) : (
                     <!-- Abstract Graphic -->
                     <svg class="absolute inset-0 w-full h-full opacity-30" viewBox="0 0 360 200" xmlns="http://www.w3.org/2000/svg">
                        <g stroke="#ffffff" stroke-width="0.5" fill="none">
                           {Array.from({length: 20}).map((_, i) => (
                             <circle cx="180" cy="100" r={i*8} opacity={1 - i/20} />
                           ))}
                        </g>
                     </svg>
                    )}
                  </div>
                  
                  <!-- Card Content -->
                  <div class="p-6 flex flex-col grow">
                    <span class="text-xs font-mono font-bold text-gray-400 mb-3 tracking-widest uppercase">
                      {article.date}
                    </span>
                    <h3 class="text-xl font-bold font-sans text-gray-900 mb-6 group-hover:text-[var(--color-accent-primary)] transition-colors leading-snug">
                      {article.title}
                    </h3>
                    
                    <div class="mt-auto pt-4 border-t border-gray-100">
                      <span class="text-sm font-semibold text-[var(--color-accent-primary)]">
                        {article.category}
                      </span>
                    </div>
                  </div>
                </Component>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  function setupArticlesScroll() {
    const container = document.getElementById('articles-scroll');
    const prevBtn = document.getElementById('articles-prev');
    const nextBtn = document.getElementById('articles-next');

    if (container && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        const cardWidth = container.querySelector('.group')?.clientWidth || 300;
        container.scrollBy({ left: -(cardWidth + 24), behavior: 'smooth' });
      });
      nextBtn.addEventListener('click', () => {
        const cardWidth = container.querySelector('.group')?.clientWidth || 300;
        container.scrollBy({ left: (cardWidth + 24), behavior: 'smooth' });
      });
    }
  }

  // Setup on initial load
  setupArticlesScroll();
</script>
