---
import { siteConfig } from "../config";
const base = import.meta.env.BASE_URL;

// Generate Top Left Curves (Sweeping Topographic Waves)
const topLeftCurves = [];
const numLinesTL = 35;
let currentYTL = -100;

for (let i = 0; i < numLinesTL; i++) {
  // Base spacing varies organically
  currentYTL += (12 + Math.sin(i * 0.25) * 8); 
  
  let path = [];
  // High-resolution polyline stepping across X
  for (let x = -50; x <= 1150; x += 20) {
      const trend = (x * 0.15);
      const largeWave = Math.sin(x * 0.005) * 150;
      // Phase shifts with 'i' to make lines bunch and spread (the topographic effect)
      const secWave = Math.cos(x * 0.01 + i * 0.1) * 50;
      const ampMod = 0.5 + (i / numLinesTL) * 1.0;
      
      const y = currentYTL + trend + (largeWave * ampMod) + secWave;
      path.push(`${x === -50 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`);
  }
  topLeftCurves.push(path.join(' '));
}

// Generate Bottom Right Curves (Sweeping Topographic Waves)
const bottomRightCurves = [];
const numLinesBR = 42;
let currentYBR = 1150;

for (let i = 0; i < numLinesBR; i++) {
  currentYBR -= (10 + Math.sin(i * 0.2) * 6); 
  
  let path = [];
  for (let x = 50; x <= 1050; x += 20) {
      const trend = - (x * 0.25);
      const largeWave = Math.sin(x * 0.004) * 200;
      const secWave = Math.sin(x * 0.009 + i * 0.08) * 60;
      const ampMod = 0.6 + (i / numLinesBR) * 0.8;
      
      const y = currentYBR + trend + (largeWave * ampMod) + secWave;
      path.push(`${x === 50 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`);
  }
  bottomRightCurves.push(path.join(' '));
}

// Generate Point Clouds (Restricted perfectly to the topographic boundaries)
const dots = [];
const dotSpacing = 16;
for (let x = 0; x <= 1000; x += dotSpacing) {
  for (let y = 0; y <= 1000; y += dotSpacing) {
    // Exact contour matching with the wave functions
    const boundaryBR = 720 - (x * 0.25) + (Math.sin(x * 0.004) * 200 * 1.4) + Math.sin(x * 0.009 + 41 * 0.08) * 60;
    const boundaryTL = 320 + (x * 0.15) + (Math.sin(x * 0.005) * 150 * 1.5) + Math.cos(x * 0.01 + 34 * 0.1) * 50;
    
    let render = false;
    let opacity = 0;
    
    if (y > boundaryBR + 30) {
       render = true;
       opacity = Math.min(0.25, (y - boundaryBR) / 150 * 0.25);
    } else if (y < boundaryTL - 30) {
       render = true;
       opacity = Math.min(0.25, (boundaryTL - y) / 150 * 0.25);
    }
    
    if (render) {
       // Add noise to opacity for texture
       opacity = opacity * (0.6 + Math.random() * 0.4);
       dots.push({ x, y, opacity: opacity.toFixed(2) });
    }
  }
}

// Mathematical Symbols (matching reference)
const symbols = [
  { char: 'Σ', x: 400, y: 150 },
  { char: 'λ', x: 250, y: 350 },
  { char: '{}', x: 650, y: 650 },
  { char: '<>', x: 500, y: 400 },
  { char: '//', x: 400, y: 700 },
  { char: '::', x: 250, y: 800 },
  { char: '⊕', x: 850, y: 550 },
  { char: '()', x: 600, y: 200 },
  { char: '→', x: 750, y: 400 },
  { char: '~', x: 800, y: 120 },
  { char: '%', x: 150, y: 600 },
  { char: '=', x: 900, y: 450 },
  { char: '=', x: 100, y: 850 }
];

// Prepare the headline to highlight "complexity into clarity."
const headlineText = siteConfig.heroHeadline || "";
const highlightStr = "complexity into clarity.";
const headlineHtml = headlineText.replace(
  highlightStr, 
  `<span class="text-[var(--color-accent-primary)]">${highlightStr}</span>`
);
---

<section id="hero" class="relative w-full h-screen min-h-[700px] max-h-[900px] overflow-hidden flex flex-col justify-between pt-32 pb-8">
  <!-- Grid Background (Layer 01) -->
  <svg class="absolute inset-0 w-full h-full -z-20 pointer-events-none opacity-[0.03]" aria-hidden="true">
    <defs>
      <pattern id="editorial-grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="1"></path>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#editorial-grid)"></rect>
  </svg>

  <div class="max-w-[1600px] mx-auto px-8 w-full flex-1 min-h-0 flex flex-col md:flex-row relative z-10">
    <!-- Left Column: Content (40%) -->
    <div class="w-full md:w-[45%] flex flex-col justify-center h-full pr-8 xl:pr-16 z-20">
      <h1 
        class="text-4xl md:text-5xl lg:text-[56px] xl:text-[64px] leading-[1.1] font-display text-gray-900 mb-6 font-medium tracking-tight animate-fade-in"
        set:html={headlineHtml}
      />
      <p class="text-lg md:text-xl text-gray-600 font-sans max-w-md mb-12 leading-relaxed animate-fade-in animation-delay-200">
        {siteConfig.heroSubheadline}
      </p>
      
      <div class="flex items-center gap-6 animate-fade-in animation-delay-400">
        <a href="#projects" class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-mono text-white bg-[#0A0D14] rounded-xl hover:bg-black transition-all hover:scale-105 shadow-sm">
          Explore My Work <span class="ml-2">↗</span>
        </a>
        <a href={`${base}/about`} class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-mono text-gray-600 border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50/50 transition-colors">
          About me
        </a>
      </div>
    </div>

  <!-- Right Column: Abstract SVG Composition (60%) -->
    <div class="hidden md:block absolute right-0 top-0 w-[60%] h-full -z-10 overflow-hidden" aria-hidden="true">
      <svg class="w-full h-full" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
        
        <g class="animate-breathe">
          <!-- Crosshair Grid -->
          <g stroke="var(--color-text-main)" stroke-width="0.4" opacity="0.12">
            <!-- Horizontal Lines -->
            <line x1="0" y1="200" x2="1000" y2="200" stroke-dasharray="1 6" />
            <line x1="0" y1="400" x2="1000" y2="400" stroke-dasharray="1 6" />
            <line x1="0" y1="600" x2="1000" y2="600" stroke-dasharray="1 6" />
            <line x1="0" y1="800" x2="1000" y2="800" stroke-dasharray="1 6" />
            <!-- Vertical Lines -->
            <line x1="200" y1="0" x2="200" y2="1000" stroke-dasharray="1 6" />
            <line x1="400" y1="0" x2="400" y2="1000" stroke-dasharray="1 6" />
            <line x1="600" y1="0" x2="600" y2="1000" stroke-dasharray="1 6" />
            <line x1="800" y1="0" x2="800" y2="1000" stroke-dasharray="1 6" />
            
            <!-- Crosshairs (+) at intersections -->
            {
              [200, 400, 600, 800].map(x => 
                [200, 400, 600, 800].map(y => (
                  <g transform={`translate(${x}, ${y})`} stroke="var(--color-accent-primary)" opacity="0.8" stroke-width="0.8">
                    <line x1="-5" y1="0" x2="5" y2="0" />
                    <line x1="0" y1="-5" x2="0" y2="5" />
                  </g>
                ))
              )
            }
          </g>

          <!-- Point Clouds (Dots) -->
          <g fill="var(--color-text-main)">
            {dots.map(d => <circle cx={d.x} cy={d.y} r="0.8" opacity={d.opacity} />)}
          </g>

          <!-- Topographic Curves -->
          <g stroke="var(--color-text-main)" stroke-width="0.8" fill="none" opacity="0.45" stroke-linecap="round" stroke-linejoin="round">
            <animate attributeName="opacity" values="0.35;0.65;0.35" dur="5s" repeatCount="indefinite" />
            {topLeftCurves.map((d, i) => <path d={d} />)}
            {bottomRightCurves.map((d, i) => <path d={d} />)}
          </g>

          <!-- Mathematical Symbols -->
          <g font-family="monospace" font-size="13" fill="var(--color-text-main)" opacity="0.4">
            {symbols.map(s => <text x={s.x} y={s.y} text-anchor="middle">{s.char}</text>)}
          </g>
        </g>
      </svg>
      
      <!-- Gradient masks to blend the SVG perfectly with the background -->
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg-base)] via-[var(--color-bg-base)]/80 to-transparent w-[40%]"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-base)] via-transparent to-transparent h-[20%] top-auto bottom-0 w-full"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg-base)] via-transparent to-transparent h-[20%] w-full"></div>
    </div>
  </div>

  <!-- Bottom Bar: Social & Vocabulary -->
  <div class="max-w-[1600px] mx-auto px-8 w-full flex flex-col md:flex-row justify-between items-end md:items-center text-xs font-mono text-gray-400 uppercase tracking-[0.2em] gap-6 mt-8 z-20 animate-fade-in animation-delay-600">
    <div class="flex items-center gap-8">
      <span class="mr-2 text-gray-500 font-semibold tracking-widest text-[10px]">LET'S CONNECT</span>
      {
        siteConfig.social?.email && (
          <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="hover:text-black transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
              <path d="M3 7l9 6l9 -6" />
            </svg>
          </a>
        )
      }
      {
        siteConfig.social?.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-black transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
        )
      }
      {
        siteConfig.social?.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hover:text-black transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
          </a>
        )
      }
    </div>

    <div class="hidden lg:flex items-center gap-10 text-[10px] font-semibold tracking-widest text-gray-500">
      <div class="flex items-center gap-3">
        <span class="text-gray-300">○</span>
        <span>ARCHITECTURE</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gray-300">○</span>
        <span>DATA</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gray-300">○</span>
        <span>AI</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gray-300">○</span>
        <span>SYSTEMS THINKING</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gray-300">○</span>
        <span>RESEARCH</span>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes breathe {
    0% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(1.02) translate(-5px, 5px); }
    100% { transform: scale(1) translate(0, 0); }
  }

  .animate-fade-in {
    animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .animate-breathe {
    animation: breathe 25s ease-in-out infinite;
    transform-origin: center;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }
</style>
